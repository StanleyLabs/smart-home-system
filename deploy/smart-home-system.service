[Unit]
Description=Smart Home System
Documentation=https://github.com/stanleylabs/smart-home-system
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=smarthub
Group=smarthub
WorkingDirectory=/opt/smart-home-system
ExecStart=/usr/bin/node dist/index.js
Restart=on-failure
RestartSec=5

# Graceful shutdown via SIGTERM (handled by the hub)
KillSignal=SIGTERM
TimeoutStopSec=15

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/smart-home-system/data /opt/smart-home-system/config

# CAP_NET_BIND_SERVICE = bind port 80 without root
# CAP_NET_RAW = BLE HCI sockets for Matter BLE commissioning
AmbientCapabilities=CAP_NET_RAW CAP_NET_BIND_SERVICE

# Environment
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
